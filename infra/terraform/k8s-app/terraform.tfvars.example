image              = "registry.example.com/chatlite:latest"
app_secret         = "replace-with-a-long-random-secret"
# database_url     = "postgresql://user:password@host:5432/chatlite"
namespace          = "chatlite"
replicas           = 1
ingress_enabled    = true
ingress_host       = "chatlite.example.com"
ingress_class_name = "nginx"
